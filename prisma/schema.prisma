// ─── Cleaning Assignment ───────────────────────────────────────────────────

enum CleaningStatus {
  PENDING
  SUBMITTED
  VALIDATED
  FAILED
  OVERDUE
}

model CleaningAssignment {
  id          String         @id @default(cuid())
  tenantId    String
  unitId      String
  token       String         @unique @default(cuid())
  weekOf      DateTime
  status      CleaningStatus @default(PENDING)
  photos      Json?
  validatedAt DateTime?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  unit   Unit   @relation(fields: [unitId], references: [id])

  @@index([tenantId])
  @@index([unitId])
  @@index([weekOf])
}

// ─── Task ─────────────────────────────────────────────────────────────────

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DISMISSED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskSource {
  MANUAL
  AIR_FILTER
  MAINTENANCE
  MESSAGE
  SYSTEM
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  source      TaskSource   @default(MANUAL)
  sourceId    String?
  propertyId  String?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  property Property? @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@index([status])
  @@index([source])
  @@index([dueDate])
}

// ─── Air Filter Config ────────────────────────────────────────────────────

enum AirFilterCadence {
  MONTHS_3
  MONTHS_4
  MONTHS_6
  MONTHS_12
}

model AirFilterConfig {
  id              String           @id @default(cuid())
  propertyId      String           @unique
  cadence         AirFilterCadence @default(MONTHS_3)
  lastChangedDate DateTime?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  property Property    @relation(fields: [propertyId], references: [id])
  filters  AirFilter[]
}

// ─── Air Filter ───────────────────────────────────────────────────────────

model AirFilter {
  id              String    @id @default(cuid())
  configId        String
  label           String?
  dimensions      String
  lastChangedDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  config AirFilterConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
}

// ─── Listing ──────────────────────────────────────────────────────────────

enum ListingStatus {
  DRAFT
  POSTED
  FILLED
  EXPIRED
  REMOVED
}

enum ListingPlatform {
  FACEBOOK
  ROOMIES
  ZILLOW
  CRAIGSLIST
  APARTMENTS_COM
  OTHER
}

model Listing {
  id              String        @id @default(cuid())
  propertyId      String
  organizationId  String
  unitId          String?
  title           String
  description     String
  price           Float
  photos          Json?
  facebookPostId  String?
  status          ListingStatus @default(DRAFT)
  metadata        Json?
  platforms       Json?
  platform        String        @default("FACEBOOK")
  adCampaignId    String?
  adBudget        Float?
  adDurationDays  Int?
  adType          String?
  marketplaceUrl  String?
  bedrooms        Int?
  bathrooms       Float?
  availableDate   DateTime?
  postedAt        DateTime?
  expiresAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  property      Property               @relation(fields: [propertyId], references: [id])
  unit          Unit?                  @relation(fields: [unitId], references: [id])
  conversations FacebookConversation[]

  @@index([propertyId])
  @@index([organizationId])
  @@index([status])
  @@index([unitId])
}

// ─── Property Profile ─────────────────────────────────────────────────────

model PropertyProfile {
  id             String   @id @default(cuid())
  propertyId     String   @unique
  description    String?
  photos         Json?
  amenities      Json?
  petPolicy      String?
  petDeposit     Float?
  smokingAllowed Boolean  @default(false)
  maxOccupants   Int?
  parkingSpaces  Int?
  laundry        String?
  customRules    Json?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id])
}

// ─── Facebook Conversation ────────────────────────────────────────────────

enum ConversationStage {
  INITIAL_INQUIRY
  ANSWERING_QUESTIONS
  PROPOSING_TIMES
  AWAITING_SELECTION
  CONFIRMING_BOOKING
  SHOWING_BOOKED
  DECLINED
  STALE
}

model FacebookConversation {
  id             String            @id @default(cuid())
  senderPsid     String
  listingId      String?
  propertyId     String
  stage          ConversationStage @default(INITIAL_INQUIRY)
  prospectName   String?
  prospectPhone  String?
  prospectEmail  String?
  showingId      String?
  proposedSlots  Json?
  messageCount   Int               @default(0)
  lastMessageAt  DateTime          @default(now())
  humanTakeover  Boolean           @default(false)
  adReferralRef  String?
  adId           String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  listing  Listing?  @relation(fields: [listingId], references: [id])
  property Property  @relation(fields: [propertyId], references: [id])

  @@unique([senderPsid, propertyId])
  @@index([senderPsid])
  @@index([stage])
  @@index([lastMessageAt])
}
